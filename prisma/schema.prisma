// prisma/shema.prisma  (filename kept to match existing project convention)
// To apply: npx prisma db push  OR  npx prisma migrate dev --name init
// Set DATABASE_URL=file:./Nexus.db in your .env file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id           Int          @id @default(autoincrement())
  name         String
  role         String       @default("employee")
  email        String?      @unique
  createdAt    DateTime     @default(now()) @map("created_at")
  shifts       Shift[]
  clockEntries ClockEntry[]

  sentMessages  Message[]                 @relation("SentMessages")
  conversations ConversationParticipant[]
}

model Shift {
  shiftId   Int       @id @default(autoincrement()) @map("shift_ID")
  date      String
  startTime String    @map("start_time")
  endTime   String    @map("end_time")
  personId  Int?      @map("person_ID")
  employee  Employee? @relation(fields: [personId], references: [id])
}

model ClockEntry {
  id              Int       @id @default(autoincrement())
  personId        Int       @map("person_ID")
  clockIn         DateTime  @map("clock_in")
  clockOut        DateTime? @map("clock_out")
  date            String
  durationMinutes Int?      @map("duration_minutes")
  employee        Employee  @relation(fields: [personId], references: [id], onDelete: Cascade)
}

model Conversation {
  id           Int                       @id @default(autoincrement())
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  participants ConversationParticipant[]
  messages     Message[]
}

model ConversationParticipant {
  id             Int @id @default(autoincrement())
  conversationId Int
  employeeId     Int

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([conversationId, employeeId])
}

model Message {
  id             Int      @id @default(autoincrement())
  conversationId Int
  senderId       Int
  content        String
  createdAt      DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Employee     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
}
