// prisma/shema.prisma  (filename kept to match existing project convention)
// To apply: npx prisma db push  OR  npx prisma migrate dev --name init
// Set DATABASE_URL=file:./Nexus.db in your .env file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id           Int          @id @default(autoincrement())
  name         String
  role         String       @default("employee")
  email        String?      @unique
  createdAt    DateTime     @default(now()) @map("created_at")
  shifts       Shift[]
  clockEntries ClockEntry[]
}

model Shift {
  shiftId   Int       @id @default(autoincrement()) @map("shift_ID")
  date      String
  startTime String    @map("start_time")
  endTime   String    @map("end_time")
  personId  Int?      @map("person_ID")
  employee  Employee? @relation(fields: [personId], references: [id])
}

model ClockEntry {
  id              Int       @id @default(autoincrement())
  personId        Int       @map("person_ID")
  clockIn         DateTime  @map("clock_in")
  clockOut        DateTime? @map("clock_out")
  date            String
  durationMinutes Int?      @map("duration_minutes")
  employee        Employee  @relation(fields: [personId], references: [id], onDelete: Cascade)
}

